---
// Calendar Component using FullCalendar
import { store } from '../store.js';
---

<div id="calendar" class="calendar-container neo-box"></div>

<script>
  import { store } from '../store.js';
  import { Calendar } from '@fullcalendar/core';
  import dayGridPlugin from '@fullcalendar/daygrid';
  import interactionPlugin from '@fullcalendar/interaction';

  let calendar: Calendar | null = null;
  let selectedDate = new Date().toISOString().split('T')[0];

  function initCalendar() {
    const calendarEl = document.getElementById('calendar');
    if (!calendarEl) return;

    calendar = new Calendar(calendarEl, {
      plugins: [dayGridPlugin, interactionPlugin],
      initialView: 'dayGridMonth',
      headerToolbar: {
        left: 'prev',
        center: 'title',
        right: 'next'
      },
      height: 'auto',
      aspectRatio: 1.5,
      selectable: true,
      editable: false,
      dayMaxEvents: true,
      events: getCalendarEvents(),
      dateClick: (info) => {
        selectedDate = info.dateStr;
        
        // Update selected date visual
        document.querySelectorAll('.fc-daygrid-day').forEach((el: HTMLElement) => {
          el.classList.remove('fc-day-selected');
        });
        info.dayEl.classList.add('fc-day-selected');
        
        // Dispatch event for other components
        window.dispatchEvent(new CustomEvent('calendarDateSelected', {
          detail: { date: selectedDate }
        }));
      },
      dayCellDidMount: (info) => {
        // Highlight today
        const today = new Date();
        const cellDate = new Date(info.date);
        if (cellDate.toDateString() === today.toDateString()) {
          info.el.classList.add('fc-day-today');
        }
        
        // Highlight selected date
        if (info.dateStr === selectedDate) {
          info.el.classList.add('fc-day-selected');
        }
      }
    });

    calendar.render();
  }

  function getCalendarEvents() {
    const state = store.getState();
    const events: any[] = [];
    
    // Group todos by date
    const todosByDate = new Map<string, number>();
    state.todos.forEach(todo => {
      const count = todosByDate.get(todo.date) || 0;
      todosByDate.set(todo.date, count + 1);
    });

    // Create events for dates with todos
    todosByDate.forEach((count, date) => {
      events.push({
        title: `${count} task${count > 1 ? 's' : ''}`,
        start: date,
        allDay: true,
        backgroundColor: 'transparent',
        borderColor: 'transparent',
        textColor: '#4CD1E0',
        className: 'todo-event'
      });
    });

    return events;
  }

  function updateCalendar() {
    if (calendar) {
      calendar.removeAllEvents();
      getCalendarEvents().forEach(event => calendar?.addEvent(event));
    }
  }

  function init() {
    initCalendar();
    store.onChange(updateCalendar);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>

<style>
  /* FullCalendar Base Styles */
  .fc {
    direction: ltr;
    text-align: left;
  }

  .fc-theme-standard td,
  .fc-theme-standard th {
    border: 1px solid #ddd;
  }

  .fc {
    font-size: 1em;
  }

  .fc .fc-button {
    border-radius: 0.25em;
    display: inline-block;
    font-size: 0.85em;
    font-weight: 400;
    line-height: 1.5;
    padding: 0.4em 0.65em;
    white-space: nowrap;
    cursor: pointer;
  }

  .fc .fc-button-primary {
    color: #fff;
    background-color: #2c3e50;
    border-color: #2c3e50;
  }

  .fc .fc-button-primary:hover {
    background-color: #1e2b37;
    border-color: #1e2b37;
  }

  .fc .fc-button-primary:disabled {
    color: #fff;
    background-color: #2c3e50;
    border-color: #2c3e50;
    opacity: 0.65;
  }

  .fc .fc-button-primary:not(:disabled):active,
  .fc .fc-button-primary:not(:disabled).fc-button-active {
    color: #fff;
    background-color: #1a252f;
    border-color: #1a252f;
  }

  .fc .fc-button-primary:focus {
    box-shadow: 0 0 0 0.2rem rgba(44, 62, 80, 0.5);
  }

  .fc .fc-button .fc-icon {
    vertical-align: middle;
    font-size: 1.5em;
  }

  .fc .fc-button-group {
    display: inline-flex;
  }

  .fc .fc-button-group > .fc-button {
    border-radius: 0;
    margin-left: -1px;
  }

  .fc .fc-button-group > .fc-button:first-child {
    margin-left: 0;
  }

  .fc .fc-button-group > .fc-button:not(:first-child):not(:last-child) {
    border-radius: 0;
  }

  .fc .fc-button-group > .fc-button:first-child {
    border-top-right-radius: 0;
    border-bottom-right-radius: 0;
  }

  .fc .fc-button-group > .fc-button:last-child {
    border-top-left-radius: 0;
    border-bottom-left-radius: 0;
  }

  .fc .fc-toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5em;
  }

  .fc .fc-toolbar-title {
    font-size: 1.75em;
    margin: 0;
  }

  .fc-direction-ltr .fc-toolbar > * > :not(:first-child) {
    margin-left: 0.75em;
  }

  .fc-direction-rtl .fc-toolbar > * > :not(:first-child) {
    margin-right: 0.75em;
  }

  .fc .fc-toolbar-chunk {
    display: flex;
    align-items: center;
  }

  .fc .fc-daygrid {
    border: 1px solid #ddd;
  }

  .fc .fc-daygrid-day {
    background: 0 0;
    position: relative;
    min-height: 100px;
  }

  .fc .fc-daygrid-day-frame {
    position: relative;
    height: 100%;
  }

  .fc .fc-daygrid-day-top {
    display: flex;
    flex-direction: row-reverse;
  }

  .fc .fc-daygrid-day-number {
    padding: 4px;
    font-size: 0.8em;
    font-weight: 400;
  }

  .fc .fc-col-header-cell {
    text-align: center;
    padding: 4px 0;
  }

  .fc .fc-col-header-cell-cushion {
    padding: 0.5em;
  }

  .fc .fc-daygrid-event {
    margin-top: 4px;
  }

  .fc .fc-daygrid-block-event .fc-event-time {
    font-weight: 700;
  }

  .fc .fc-daygrid-block-event .fc-event-title {
    font-weight: 400;
  }

  .fc .fc-daygrid-event-harness {
    position: relative;
  }

  .fc .fc-daygrid-more-link {
    position: absolute;
    z-index: 6;
    padding: 2px;
    cursor: pointer;
  }

  .fc .fc-daygrid-more-link:hover {
    text-decoration: underline;
  }

  .fc .fc-daygrid-week-frame {
    border: 1px solid #ddd;
  }

  .fc .fc-daygrid-day-frame {
    min-height: 100px;
  }

  /* Custom Calendar Styles */
  .calendar-container {
    padding: 1rem;
    margin-bottom: 1.5rem;
  }

  .fc {
    font-family: 'Space Grotesk', system-ui, sans-serif;
  }

  .fc-toolbar-title {
    font-size: 1.25rem;
    font-weight: bold;
  }

  .fc-button {
    background-color: var(--yellow) !important;
    border: var(--border) !important;
    box-shadow: var(--shadow) !important;
    border-radius: 8px !important;
    font-weight: bold !important;
    font-family: inherit !important;
    padding: 0.5rem 1rem !important;
    transition: all 0.1s ease !important;
  }

  .fc-button:hover {
    transform: translate(2px, 2px);
    box-shadow: var(--shadow-hover) !important;
  }

  .fc-button:active {
    transform: translate(4px, 4px);
    box-shadow: none !important;
  }

  .fc-daygrid-day {
    border: 2px solid #eee !important;
    border-radius: 8px !important;
    transition: all 0.2s ease;
    cursor: pointer;
  }

  .fc-daygrid-day:hover {
    border-color: var(--yellow) !important;
    transform: translateY(-2px);
  }

  .fc-day-today {
    background-color: var(--yellow) !important;
    font-weight: bold;
    border-color: var(--black) !important;
  }

  .fc-day-selected {
    background-color: #e0f2fe !important;
    border-color: var(--blue) !important;
    box-shadow: var(--shadow);
  }

  .fc-daygrid-day-number {
    font-weight: 600;
  }

  .todo-event {
    font-size: 0.75rem;
    padding: 2px 6px;
    border-radius: 4px;
    background-color: rgba(76, 209, 224, 0.1);
    border: 1px solid var(--blue);
  }

  @media (max-width: 768px) {
    .calendar-container {
      padding: 0.5rem;
    }

    .fc-toolbar-title {
      font-size: 1rem;
    }

    .fc-button {
      padding: 0.4rem 0.75rem !important;
      font-size: 0.85rem !important;
    }

    .fc-daygrid-day-number {
      font-size: 0.85rem;
    }

    .todo-event {
      font-size: 0.65rem;
    }
  }
</style>

---
import '../styles/global.css';
import Navigation from '../components/Navigation.astro';
import { pwaInfo } from 'virtual:pwa-info';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
		<link rel="icon" type="image/png" href="/icon.png" />
		<meta name="generator" content={Astro.generator} />
		<meta name="theme-color" content="#FDFCE3" />
		<link rel="manifest" href="/manifest.webmanifest" />
		<title>DailySprout</title>
		<script src="https://cdn.tailwindcss.com"></script>

		<script src="/src/pwa.ts"></script>
		{ pwaInfo && <Fragment set:html={pwaInfo.webManifest.linkTag} /> }
	</head>
	<body>
		<div class="app-container">
			<Navigation />
			<main class="main-content">
				<slot />
			</main>
			<footer class="footer">
				<p>Made with 🌱 by <a href="https://github.com/Fir3fliesss" target="_blank" rel="noopener noreferrer">fireflies05</a></p>
			</footer>
		</div>
	</body>
</html>

<style>
	.app-container {
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		background-color: var(--bg);
	}

	.main-content {
		flex: 1;
		padding-bottom: 80px; /* Space for bottom nav */
		max-width: 100%;
		margin: 0 auto;
	}

	@media (min-width: 769px) {
		.main-content {
			max-width: 480px;
			padding: 2rem 1rem 100px 1rem;
		}
	}

	.footer {
		text-align: center;
		padding: 1.5rem 1rem 6rem 1rem; /* Extra bottom padding for mobile nav */
		font-size: 0.9rem;
		font-weight: 500;
	}

	.footer a {
		color: var(--black);
		text-decoration: underline;
		font-weight: 700;
	}

	.footer a:hover {
		color: var(--green);
	}
</style>
